class Js {
  def exec(String e) {
    Sys.exec(e);
  }
  
  def getKey(vant.Key.k key) {
      var result = Sys.exec(`
        let result = false;
        window.addEventListener("keydown", function(e) {
           result = true;
        });
        return result;
      `);
      exit sys.getBResult();
  }
}
