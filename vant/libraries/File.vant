import { Js } from "./Js";

class File {
  var path = "";

  construct(p: string) {
    self.path = p;
  }

  def mkdirs() {
    // Enviamos la ruta al puente JS
    Js.exec(`
      let fs = require('fs');
      if (!fs.existsSync("${self.path}")) {
          fs.mkdirSync("${self.path}", { recursive: true });
      }
    `);
  }
}
